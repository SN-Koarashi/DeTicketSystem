{
  "name": "hono",
  "type": "module",
  "license": "GPL-3.0-only",
  "scripts": {
    "dev": "wrangler dev --port 8081",
    "dev:remote": "wrangler dev --port 8081 --ip 0.0.0.0",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "init:db": "wrangler d1 execute events --local --command \"CREATE TABLE events (id INTEGER PRIMARY KEY AUTOINCREMENT, cid TEXT NOT NULL, summary BLOB NOT NULL);\""
  },
  "dependencies": {
    "@reown/appkit": "^1.8.14",
    "@reown/appkit-siwx": "^1.8.14",
    "bcryptjs": "^2.4.3",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.0.0",
    "file-type": "^21.1.1",
    "hono": "^4.10.3",
    "siwe": "^3.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251121.0",
    "@types/node": "^24.9.2",
    "@types/react": "^19.2.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.4.0"
  }
}